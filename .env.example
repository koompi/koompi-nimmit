# Nimmit Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit the actual .env file

# Telegram Bot (required)
# Create at https://t.me/BotFather
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# AI Model API Keys (at least one required)
GOOGLE_API_KEY=AIzaSy...              # Get at https://aistudio.google.com/apikey
ZAI_API_KEY=                           # Alternative provider
COPILOT_TOKEN=ghp_...                  # GitHub Copilot, if you have it

# Optional
PRIMARY_MODEL=google/gemini-3.1-pro-preview
TIMEZONE=UTC
LANGUAGE=en
