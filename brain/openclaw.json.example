{
  "name": "{{AGENT_NAME_LOWER}}",
  "version": "1.0.0",
  "company": "{{COMPANY}}",
  "agent": {
    "name": "{{AGENT_NAME}}",
    "handle": "@{{BOT_USERNAME}}"
  },
  "owner": {
    "name": "{{OWNER_NAME}}",
    "id": "{{OWNER_ID}}"
  },
  "locale": {
    "timezone": "{{TIMEZONE}}",
    "language": "{{LANGUAGE}}"
  },
  "brain": {
    "root": "./",
    "soul": "SOUL.md",
    "identity": "IDENTITY.md",
    "architecture": "ARCHITECTURE.md",
    "agents": "AGENTS.md",
    "tools": "TOOLS.md",
    "heartbeat": "HEARTBEAT.md",
    "workflow": "WORKFLOW.md",
    "memory": "memory/",
    "topics": "topics/"
  },
  "model": {
    "primary": "google/gemini-3.1-pro-preview",
    "fallbacks": [
      "google/gemini-3-flash-preview",
      "github-copilot/claude-sonnet-4.6"
    ],
    "image": "google/gemini-3.1-flash-image-preview",
    "coding": {
      "copilot": ["github-copilot/claude-opus-4.6", "github-copilot/gpt-5.4"],
      "deep": "claude-code-acp"
    }
  },
  "integrations": {
    "messaging": {
      "platform": "telegram",
      "bot_username": "{{BOT_USERNAME}}"
    },
    "code": {
      "provider": "github",
      "org": ""
    }
  },
  "heartbeat": {
    "daily_sync": "09:00",
    "weekly_intel": "monday",
    "monthly_review": "first_monday",
    "memory_consolidation": "18:00"
  }
}
